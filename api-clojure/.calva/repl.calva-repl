;;               {:tipo "exercicio", :nome "corrida", :data "2026-06-12", :calorias 300})}

(defn extrato-transacoes []
  (let [transacoes (buscar-transacoes)
        calorias-adquiridas (reduce + (map :calorias transacoes))]
    (print calorias-adquiridas)
    ))

