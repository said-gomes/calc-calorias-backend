(ns backend.request
  (:require [clj-http.client :as client]
            [cheshire.core :refer [parse-string]]
            [clojure.edn :as edn]))

(def config (edn/read-string (slurp ".edn")))

(def chave (:api-key config))

(def api-url "https://api.api-ninjas.com/v1/caloriesburned")

(client/get api-url
            {:query-params {"activity" "running"
                            "weight"   70
                            "duration" 30}
             :headers      {"X-Api-Key" chave}})

